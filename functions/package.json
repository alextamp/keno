  },
  "engines": { "node": "20" },
  "main": "lib/index.js",
  "dependencies": {
    "expo-server-sdk": "^3.10.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5"
  },
  "private": true
}
