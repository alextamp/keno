rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function onlyChangedFields(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // User profiles
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      // Owners can edit their whole profile. Anyone else may only union an
      // event into joinedEvents — needed when a leaving attendee promotes the
      // next person off an event's waitlist into someone else's joined list.
      allow update: if isOwner(userId) ||
        (signedIn() && onlyChangedFields(['joinedEvents']));
      allow delete: if false;

      // Per-user notifications (actual storage path — not the root collection below)
      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if signedIn();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    // Events + subcollections
    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.creatorId == request.auth.uid;
      // Creator can edit everything; anyone else can only touch join/waitlist/reaction state.
      allow update: if signedIn() && (
        resource.data.creatorId == request.auth.uid ||
        onlyChangedFields(['attendeeIds', 'waitlistIds', 'reactions'])
      );
      allow delete: if signedIn() && resource.data.creatorId == request.auth.uid;

      // Public comments
      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update: if signedIn() && resource.data.userId == request.auth.uid;
        allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      }

      // Chat messages
      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        // Reactions are added/removed by users other than the author.
        allow update: if signedIn() && onlyChangedFields(['reactions']);
        allow delete: if false;
      }

      // Typing indicators
      match /typing/{userId} {
        allow read: if signedIn();
        allow write: if isOwner(userId);
      }
    }

    // Direct message conversations — gated to the two participants only.
    match /conversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if signedIn() && request.auth.uid in resource.data.participantIds;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow create: if signedIn() &&
          request.resource.data.senderId == request.auth.uid &&
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds;
        allow update: if false;
        allow delete: if false;
      }
    }

    // Communities / groups
    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.creatorId == request.auth.uid;
      // Creator can edit everything; members can only join/leave or accept invites,
      // and any signed-in user can attach an event they posted to the group.
      allow update: if signedIn() && (
        resource.data.creatorId == request.auth.uid ||
        onlyChangedFields(['memberIds', 'invitedUserIds', 'eventIds'])
      );
      allow delete: if signedIn() && resource.data.creatorId == request.auth.uid;

      match /messages/{messageId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if false;
      }
    }

    // User reports — write-only from clients, no client read access.
    match /reports/{reportId} {
      allow read: if false;
      allow create: if signedIn() && request.resource.data.reporterUid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
  }
}
